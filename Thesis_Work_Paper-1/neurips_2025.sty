% neurips_2025.sty — minimal stub for local compilation
% Replace with the official NeurIPS 2025 style file from neurips.cc before submission
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 stub]

\DeclareOption{preprint}{\def\@preprint{1}}
\DeclareOption{final}{}
\ProcessOptions\relax

% Page geometry
\RequirePackage[letterpaper,
  top=1in, bottom=1in,
  left=1.25in, right=1.25in]{geometry}

% Font setup
\RequirePackage{times}
\RequirePackage{helvet}
\RequirePackage{courier}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Paragraph spacing
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt}

% Line spacing
\linespread{1.05}

% Caption formatting
\RequirePackage[font=small,labelfont=bf]{caption}

% Preprint watermark
\ifdefined\@preprint
  \RequirePackage{fancyhdr}
  \pagestyle{fancy}
  \fancyhf{}
  \fancyhead[C]{\small Preprint. Under review.}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
\fi

% Abstract environment
\renewenvironment{abstract}{%
  \small
  \begin{center}
    \bfseries Abstract
  \end{center}
  \begin{quote}
}{%
  \end{quote}
}
